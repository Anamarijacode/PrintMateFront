<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.PrintMate" parent="Theme.MaterialComponents.DayNight.DarkActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/purple_500</item>
        <item name="colorPrimaryVariant">@color/purple_700</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/teal_200</item>
        <item name="colorSecondaryVariant">@color/teal_700</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">?attr/colorPrimaryVariant</item>
        <!-- Customize your theme here. -->
    </style>
    <!--Pozadine-->
    <color name="background_color_primary">#65558F</color>
    <color name="background_color_secondary">#F5F5F5</color>
    <!--Gumbi-->
    <color name="button_color_primary">#65558F</color>
    <color name="button_color_secondary">#EADDFF</color>

    <!--Inputi-->
    <color name="input_primary">#F1EBFC</color>

    <!--Text-->
    <color name="text_color_primary">#3B1D71</color>
    <color name="text_color_secondary">#F5F5F5</color>
</resources>