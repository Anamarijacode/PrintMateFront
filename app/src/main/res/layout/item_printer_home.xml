<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
xmlns:android="http://schemas.android.com/apk/res/android"
xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
android:layout_height="wrap_content"
android:layout_margin="12dp"
android:background="@drawable/rounded_layout"
android:padding="12dp">

<ImageView
    android:id="@+id/printerSlika"
    android:layout_width="100dp"
    android:layout_height="100dp"
    android:layout_marginStart="20dp"
    android:scaleType="centerCrop"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent"
    app:layout_constraintVertical_bias="1.0" />

    <TextView
        android:id="@+id/printerNaziv"
        android:layout_width="200dp"
        android:layout_height="27dp"
        android:layout_marginStart="34dp"
        android:layout_marginEnd="8dp"
        android:fontFamily="@font/actor"
        android:text="Naziv printera"
        android:textAlignment="center"
        android:textColor="@color/text_color"
        android:textSize="18sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/printerSlika"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/printerStatus"
        android:layout_width="126dp"
        android:layout_height="30dp"
        android:layout_marginStart="111dp"
        android:layout_marginTop="41dp"
        android:layout_marginEnd="17dp"
        android:fontFamily="@font/roboto_bold"
        android:gravity="bottom|right"
        android:text="Online/Offline"
        android:textColor="@color/printMateDarkPurlupel"
        android:textSize="14sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/printerSlika"
        app:layout_constraintTop_toBottomOf="@+id/printerNaziv" />
</androidx.constraintlayout.widget.ConstraintLayout>